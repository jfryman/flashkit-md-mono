<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pres="using:FlashKit.Presentation"
        x:Class="FlashKit.Gui.MainWindow"
        Title="Flashkit-md"
        Icon="/Assets/flashkit.ico"
        Width="820" Height="628"
        MinWidth="700" MinHeight="628">

  <Window.Styles>
    <Style Selector="TextBlock.label">
      <Setter Property="Opacity" Value="0.7" />
    </Style>
    <Style Selector="TextBlock.failed">
      <Setter Property="Foreground" Value="#D9534F" />
    </Style>
    <!-- Transaction status bubble: gray (cancelled) unless a state class
         applies — amber while running, green/red on the outcome. The base
         fill lives here, not inline, so the state styles can win. -->
    <Style Selector="Ellipse.status">
      <Setter Property="Fill" Value="#8B949E" />
    </Style>
    <Style Selector="Ellipse.status.running">
      <Setter Property="Fill" Value="#D29922" />
    </Style>
    <Style Selector="Ellipse.status.ok">
      <Setter Property="Fill" Value="#3FB950" />
    </Style>
    <Style Selector="Ellipse.status.failed">
      <Setter Property="Fill" Value="#D9534F" />
    </Style>
  </Window.Styles>

  <!-- ROM/RAM button groups on the left; cart info panel and per-operation
       transaction log on the right; status bar (device + cartridge, fed by
       the background poller) along the bottom. -->
  <Grid Margin="12" ColumnDefinitions="220,12,*" RowDefinitions="*,12,Auto">

    <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="1" CornerRadius="4" Padding="10,8">
      <StackPanel Orientation="Horizontal" Spacing="24">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Ellipse x:Name="DeviceDot" Width="10" Height="10" Fill="#8B949E" VerticalAlignment="Center" />
          <TextBlock x:Name="DeviceStatusText" Text="Looking for programmer..." VerticalAlignment="Center" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Ellipse x:Name="CartDot" Width="10" Height="10" Fill="#8B949E" VerticalAlignment="Center" />
          <TextBlock x:Name="CartStatusText" Text="—" VerticalAlignment="Center" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- The last row stretches so the Auto-write panel's bottom edge always
         lines up with the transaction panel's, whatever the window size. -->
    <Grid Grid.Row="0" Grid.Column="0" RowDefinitions="Auto,12,Auto,12,Auto,12,*">
      <Border Grid.Row="0"
              BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
              BorderThickness="1" CornerRadius="4" Padding="8">
        <StackPanel Spacing="8">
          <TextBlock Text="ROM" FontWeight="SemiBold" />
          <Button x:Name="BtnReadRom" Content="Read ROM" Height="30"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                  Click="OnReadRom" />
          <Button x:Name="BtnWriteRom" Content="Write ROM" Height="30"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                  Click="OnWriteRom" />
        </StackPanel>
      </Border>

      <Border Grid.Row="2"
              BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
              BorderThickness="1" CornerRadius="4" Padding="8">
        <StackPanel Spacing="8">
          <TextBlock Text="RAM" FontWeight="SemiBold" />
          <Button x:Name="BtnReadRam" Content="Read RAM" Height="30"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                  Click="OnReadRam" />
          <Button x:Name="BtnWriteRam" Content="Write RAM" Height="30"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                  Click="OnWriteRam" />
        </StackPanel>
      </Border>

      <Border Grid.Row="4"
              BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
              BorderThickness="1" CornerRadius="4" Padding="8">
        <StackPanel Spacing="6">
          <TextBlock Text="Auto-dump" FontWeight="SemiBold" />
          <CheckBox x:Name="ChkAutoRom" Content="Dump ROM" IsCheckedChanged="OnAutoDumpToggled" />
          <CheckBox x:Name="ChkAutoRam" Content="Dump RAM" IsCheckedChanged="OnAutoDumpToggled" />
          <Button x:Name="BtnDumpFolder" Content="Choose folder..."
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                  Click="OnChooseFolder" />
          <TextBlock x:Name="AutoDumpFolderText" Text="No folder chosen" FontSize="11"
                     Opacity="0.7" TextTrimming="CharacterEllipsis" />
        </StackPanel>
      </Border>

      <Border Grid.Row="6"
              BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
              BorderThickness="1" CornerRadius="4" Padding="8">
        <StackPanel Spacing="6">
          <TextBlock Text="Auto-write" FontWeight="SemiBold" />
          <CheckBox x:Name="ChkAutoWrite" Content="Write ROM" IsCheckedChanged="OnAutoWriteToggled" />
          <Button x:Name="BtnWriteFile" Content="Choose file..."
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                  Click="OnChooseWriteFile" />
          <TextBlock x:Name="AutoWriteFileText" Text="No file chosen" FontSize="11"
                     Opacity="0.7" TextTrimming="CharacterEllipsis" />
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.Row="0" Grid.Column="2" RowDefinitions="Auto,12,*">

      <Border Grid.Row="0"
              BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
              BorderThickness="1" CornerRadius="4" Padding="10,8">
        <Grid ColumnDefinitions="130,8,*" RowDefinitions="Auto,6,Auto,6,Auto,6,Auto,6,Auto,6,Auto">
          <TextBlock Classes="label" Grid.Row="0" Grid.Column="0" Text="Cartridge" />
          <TextBlock x:Name="InfoName" Grid.Row="0" Grid.Column="2" Text="—" FontWeight="SemiBold" />
          <TextBlock Classes="label" Grid.Row="2" Grid.Column="0" Text="System" />
          <TextBlock x:Name="InfoSystem" Grid.Row="2" Grid.Column="2" Text="—" />
          <TextBlock Classes="label" Grid.Row="4" Grid.Column="0" Text="Region" />
          <TextBlock x:Name="InfoRegion" Grid.Row="4" Grid.Column="2" Text="—" />
          <TextBlock Classes="label" Grid.Row="6" Grid.Column="0" Text="ROM size" />
          <TextBlock x:Name="InfoRomSize" Grid.Row="6" Grid.Column="2" Text="—" />
          <TextBlock Classes="label" Grid.Row="8" Grid.Column="0" Text="RAM size" />
          <TextBlock x:Name="InfoRamSize" Grid.Row="8" Grid.Column="2" Text="—" />
          <TextBlock Classes="label" Grid.Row="10" Grid.Column="0" Text="Header ROM size" />
          <TextBlock x:Name="InfoHeaderSize" Grid.Row="10" Grid.Column="2" Text="—" />
        </Grid>
      </Border>

      <Border Grid.Row="2"
              BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
              BorderThickness="1" CornerRadius="4" Padding="10,8">
        <Grid RowDefinitions="Auto,8,*">
          <TextBlock Grid.Row="0" Text="Transactions" FontWeight="SemiBold" />
          <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="LogList">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="pres:TransactionEntry">
                  <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                          BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,4,8">
                    <StackPanel Spacing="4">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Classes="status" Width="10" Height="10"
                                 VerticalAlignment="Center"
                                 Classes.running="{Binding Running}"
                                 Classes.ok="{Binding Succeeded}"
                                 Classes.failed="{Binding Failed}" />
                        <TextBlock Text="{Binding Time}" FontSize="12" Opacity="0.7"
                                   FontFamily="Consolas,Menlo,DejaVu Sans Mono,monospace"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                      </StackPanel>
                      <TextBlock Text="{Binding Detail}" FontSize="12" Opacity="0.8"
                                 TextWrapping="Wrap" IsVisible="{Binding HasDetail}" />
                      <ProgressBar Height="8" Minimum="0"
                                   Maximum="{Binding ProgressMax}" Value="{Binding ProgressValue}" />
                      <TextBlock Text="{Binding Status}" FontSize="12" TextWrapping="Wrap"
                                 Classes.failed="{Binding Failed}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
